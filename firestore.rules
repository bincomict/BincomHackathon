rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Hackathon Settings Collection
    match /hackathon_settings/{settingId} {
      allow read: if true;
      allow write: if isValidId(settingId);
    }

    // 3. Registrations Collection
    match /registrations/{registrationId} {
      allow read: if true;
      allow write: if isValidId(registrationId) || registrationId != null;
    }
  }
}
